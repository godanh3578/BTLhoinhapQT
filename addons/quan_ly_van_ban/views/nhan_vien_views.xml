<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form_inherit_van_ban" model="ir.ui.view">
            <field name="name">nhan_vien.form.inherit.van_ban</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet" position="inside">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_van_ban_den"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="van_ban_den_count" widget="statinfo" string="Văn bản"/>
                        </button>
                    </div>
                </xpath>
                <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Văn bản xử lý">
                        <field name="van_ban_den_xu_ly_ids" readonly="1">
                            <tree>
                                <field name="so_van_ban"/>
                                <field name="ten_van_ban"/>
                                <field name="ngay_van_ban"/>
                                <field name="trang_thai"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Văn bản ký">
                        <field name="van_ban_den_ky_ids" readonly="1">
                            <tree>
                                <field name="so_van_ban"/>
                                <field name="ten_van_ban"/>
                                <field name="ngay_van_ban"/>
                                <field name="trang_thai"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Văn bản nhận/phối hợp">
                        <field name="van_ban_den_nhan_ids" readonly="1">
                            <tree>
                                <field name="so_van_ban"/>
                                <field name="ten_van_ban"/>
                                <field name="ngay_van_ban"/>
                                <field name="trang_thai"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>